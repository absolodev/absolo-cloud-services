# Enforce LF for all text files in this repo (we run mostly on Linux containers).
* text=auto eol=lf

# Lockfiles & generated content are best treated as binary for diffs.
pnpm-lock.yaml -diff
package-lock.json -diff
Cargo.lock -diff

# Binary file types
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
*.zip binary
