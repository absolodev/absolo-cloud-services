{
  "name": "@absolo/admin",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Internal admin console \u2014 Absolo staff only.",
  "absolo": {
    "visibility": "private",
    "publish": "no",
    "audience": "absolo-staff"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@absolo/contracts": "workspace:*",
    "@absolo/design-tokens": "workspace:*",
    "@absolo/icons": "workspace:*",
    "@absolo/sdk": "workspace:*",
    "@absolo/ui": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@absolo/tsconfig": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  }
}
