# Root .env for local development. Copy to `.env` (gitignored) and edit.
#
# Service-specific overrides live in `services/*/.env` and `apps/*/.env.local`
# for convenience while iterating, but the values here are the canonical ones
# referenced by `docker-compose.yml` and consumed by every workspace package
# during `pnpm dev`.

# ---------- Postgres ----------
POSTGRES_USER=absolo
POSTGRES_PASSWORD=absolo
POSTGRES_DB=absolo
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- NATS ----------
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# ---------- MailHog ----------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ---------- Control plane (services/control-plane) ----------
DATABASE_URL=postgres://absolo:absolo@localhost:5432/absolo
SESSION_SECRET=dev-only-please-replace-this-with-a-real-secret
LOG_LEVEL=debug
LOG_PRETTY=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ---------- Frontends ----------
# apps/marketing  -> http://localhost:3000  (Next.js)
# apps/dashboard  -> http://localhost:5173  (Vite)
# apps/admin      -> http://localhost:5174  (Vite)
VITE_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
