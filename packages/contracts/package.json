{
  "name": "@absolo/contracts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Single source of truth for the Absolo public API: Zod schemas, derived TS types, and an OpenAPI 3.1 document generated from the schemas.",
  "absolo": {
    "visibility": "public",
    "publish": "future",
    "extractTo": "@absolo/contracts (npm) + absolo/api-spec (mirror)"
  },
  "exports": {
    ".": "./src/index.ts",
    "./common": "./src/common/index.ts",
    "./auth": "./src/auth/index.ts",
    "./orgs": "./src/orgs/index.ts",
    "./projects": "./src/projects/index.ts",
    "./environments": "./src/environments/index.ts",
    "./config": "./src/config/index.ts",
    "./errors": "./src/errors.ts",
    "./openapi": "./src/openapi.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src", "openapi/openapi.gen.yaml"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "gen:openapi": "tsx scripts/gen-openapi.ts",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "openapi3-ts": "^4.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@absolo/tsconfig": "workspace:*",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8",
    "yaml": "^2.6.0"
  }
}
