{
  "name": "@absolo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Component library shared by every Absolo frontend. shadcn-derived primitives composed with Radix UI, class-variance-authority and tailwind-merge.",
  "absolo": {
    "visibility": "private",
    "publish": "future",
    "extractTo": "@absolo/ui (npm) once API stabilises"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles.css",
    "./utils": "./src/utils/cn.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src", "dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@absolo/icons": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@absolo/design-tokens": "workspace:*",
    "@absolo/tsconfig": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
