{
  "name": "@absolo/control-plane",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Absolo control plane \u2014 the public REST API. NestJS 11 over Fastify, Postgres via Drizzle, contracts validated with Zod from @absolo/contracts.",
  "absolo": {
    "visibility": "private",
    "publish": "no",
    "contains": ["plan-04", "plan-08", "plan-28", "plan-29", "plan-41"]
  },
  "main": "./src/main.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@absolo/contracts": "workspace:*",
    "@fastify/cookie": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ulidx": "^2.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@absolo/tsconfig": "workspace:*",
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
