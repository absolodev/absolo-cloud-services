# Control plane local-dev defaults. Copy to `.env` and adjust.

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Postgres (matches docker-compose.yml in repo root once that lands)
DATABASE_URL=postgres://absolo:absolo@localhost:5432/absolo
DATABASE_POOL_MAX=10

# Auth — REPLACE before going to staging or production.
SESSION_SECRET=dev-only-please-replace-this-with-a-real-secret

# CORS — comma-separated list of allowed origins (no trailing slash).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
